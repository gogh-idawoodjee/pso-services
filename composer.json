{
    "name": "gogh-idawoodjee/pso-services",
    "type": "project",
    "description": "A Laravel-based application.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "support": {
        "issues": "https://github.com/gogh-idawoodjee/pso-services/issues",
        "source": "https://github.com/gogh-idawoodjee/pso-services"
    },
    "require": {
        "php": "^8.3",
        "ext-bcmath": "*",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "alexpechkarev/google-maps": "^12.14",
        "dedoc/scramble": "^0.13",
        "gogh-idawoodjee/shortcode": "^1.0",
        "laravel/framework": "^13.0",
        "laravel/nightwatch": "^1.10",
        "laravel/sanctum": "^4.1",
        "laravel/tinker": "^3.0",
        "spatie/geocoder": "^4.0"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.0",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.5",
        "phpunit/phpunit": "^12.1",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
