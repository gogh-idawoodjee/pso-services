###############################################################################
# Application
###############################################################################
APP_NAME="PSO Services"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

###############################################################################
# PSO Connection (IFS/PSO API)
###############################################################################
BASE_URL=https://pso.thetechnodro.me
PSO_USERNAME=
PSO_PASSWORD=
DATASET_ID=NORTH
ACCOUNT_ID=Default

###############################################################################
# PSO Defaults
###############################################################################
DEFAULT_BASE_VALUE=2000
DEFAULT_PRIORITY=1
DEFAULT_PROCESS_TYPE=APPOINTMENT
DEFAULT_TIMEOUT=5
APPOINTMENT_TEMPLATE_DURATION=21

###############################################################################
# Google Maps / Geocoding
###############################################################################
GOOGLE_MAPS_API_KEY=

###############################################################################
# Encryption
###############################################################################
SHREDDER_KEY=

###############################################################################
# Krang Database (external API database)
###############################################################################
KRANG_DB_DRIVER=mysql
KRANG_DB_HOST=127.0.0.1
KRANG_DB_PORT=3306
KRANG_DB_DATABASE=your_api_db
KRANG_DB_USERNAME=your_api_user
KRANG_DB_PASSWORD=

###############################################################################
# Primary Database
###############################################################################
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=pso_services
# DB_USERNAME=root
# DB_PASSWORD=

###############################################################################
# Logging
###############################################################################
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

###############################################################################
# Cache / Queue / Session
###############################################################################
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

###############################################################################
# Redis (uncomment if using Redis for cache/queue/session)
###############################################################################
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

###############################################################################
# API Documentation (Scramble)
###############################################################################
API_VERSION=2.0
